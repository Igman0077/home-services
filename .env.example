# Environment
DATABASE_URL="postgresql://nchs:nchs_dev_password@localhost:5432/north_country_home_services?schema=public"
AUTH_SECRET="generate-a-long-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Public site configuration (overridable via SiteSetting in admin)
NEXT_PUBLIC_SITE_NAME="North Country Home Services"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_TAGLINE="Find trusted local home service professionals across Northern New York"

# Feature flags (defaults; DB FeatureFlag rows override at runtime when present)
NEXT_PUBLIC_REVIEWS_ENABLED="false"
NEXT_PUBLIC_SHOW_SAMPLE_DATA_BADGES="true"

# Optional integrations (leave empty to use console/mock adapters)
EMAIL_PROVIDER="console"
STORAGE_PROVIDER="local"
ANALYTICS_PROVIDER="console"
AI_PROVIDER="mock"
SMS_PROVIDER="console"
MAPS_PROVIDER="mock"
PAYMENT_PROVIDER="mock"

# Seed admin (development only — change immediately)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMeNow!123"
SEED_EDITOR_EMAIL="editor@example.com"
SEED_EDITOR_PASSWORD="ChangeMeNow!123"
